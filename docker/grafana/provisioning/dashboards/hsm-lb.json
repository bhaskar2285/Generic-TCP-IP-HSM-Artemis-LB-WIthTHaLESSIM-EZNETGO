{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "HSM Thales LB — full stack monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "LB Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(hsm_lb_requests_total{result=\"success\"}[1m])) by (instance)",
          "legendFormat": "{{instance}} success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(hsm_lb_requests_total{result=\"error\"}[1m])) by (instance)",
          "legendFormat": "{{instance}} error",
          "refId": "B"
        }
      ],
      "title": "LB Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (exported_instance) (rate(hsm_lb_requests_total{result=\"error\"}[1m])) / sum by (exported_instance) (rate(hsm_lb_requests_total[1m]))",
          "legendFormat": "{{exported_instance}} error rate",
          "refId": "A"
        }
      ],
      "title": "LB Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (exported_instance) (rate(hsm_lb_request_duration_seconds_sum[1m])) / sum by (exported_instance) (rate(hsm_lb_request_duration_seconds_count[1m]))",
          "legendFormat": "{{exported_instance}} avg",
          "refId": "A"
        },
        {
          "expr": "max by (exported_instance) (hsm_lb_request_duration_seconds_max)",
          "legendFormat": "{{exported_instance}} max",
          "refId": "B"
        }
      ],
      "title": "LB Request Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }, "mappings": [{ "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [
        {
          "expr": "max by (node) (hsm_lb_node_healthy)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "HSM Node Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }, "mappings": [{ "options": { "0": { "text": "CLOSED" }, "1": { "text": "OPEN" } }, "type": "value" }] },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [
        {
          "expr": "max by (node) (hsm_lb_node_circuit_open)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Circuit Breakers",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Artemis Brokers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "artemis_queue_message_count{queue=~\"hsm.transparent.lb.*\"}",
          "legendFormat": "{{queue}} ({{instance}})",
          "refId": "A"
        }
      ],
      "title": "Queue Depth (LB queues)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "artemis_queue_consumer_count{queue=~\"hsm.transparent.lb.*\"}",
          "legendFormat": "{{queue}} consumers ({{instance}})",
          "refId": "A"
        }
      ],
      "title": "Queue Consumer Counts",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_memory_heap_used_bytes{job=\"artemis\"}",
          "legendFormat": "{{instance}} heap used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_heap_committed_bytes{job=\"artemis\"}",
          "legendFormat": "{{instance}} heap committed",
          "refId": "B"
        }
      ],
      "title": "Artemis JVM Heap",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "EZNet Instances",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_threads_ThreadCount{job=\"eznet\"}",
          "legendFormat": "{{instance}} threads",
          "refId": "A"
        }
      ],
      "title": "EZNet JVM Thread Count",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_memory_used_bytes{job=\"eznet\", area=\"heap\"})",
          "legendFormat": "{{instance}} heap",
          "refId": "A"
        }
      ],
      "title": "EZNet JVM Heap",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "HSM Simulators",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "id": 30,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(hsm_sim_requests_total[1m])",
          "legendFormat": "{{sim_id}}",
          "refId": "A"
        }
      ],
      "title": "HSM Sim Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "id": 31,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(hsm_sim_request_duration_seconds_bucket[1m])) by (le, sim_id))",
          "legendFormat": "{{sim_id}} p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(hsm_sim_request_duration_seconds_bucket[1m])) by (le, sim_id))",
          "legendFormat": "{{sim_id}} p99",
          "refId": "B"
        }
      ],
      "title": "HSM Sim Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "id": 32,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "hsm_sim_active_connections",
          "legendFormat": "{{sim_id}}",
          "refId": "A"
        }
      ],
      "title": "HSM Sim Active Connections",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Container Health (cAdvisor)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 40,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{id=~\"/system.slice/.*\", cpu=\"total\"}[1m])",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "title": "Container CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 41,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{id=~\"/system.slice/.*\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "title": "Container Memory Usage",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hsm", "artemis", "lb"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HSM Thales LB — Full Stack",
  "uid": "hsm-lb-stack",
  "version": 1
}
