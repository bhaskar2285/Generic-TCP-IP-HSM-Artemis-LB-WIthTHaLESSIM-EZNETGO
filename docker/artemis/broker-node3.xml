<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<configuration xmlns="urn:activemq"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xmlns:xi="http://www.w3.org/2001/XInclude"
               xsi:schemaLocation="urn:activemq /schema/artemis-configuration.xsd">

  <core xmlns="urn:activemq:core">
    <name>broker-3</name>
    <persistence-enabled>true</persistence-enabled>
    <journal-type>ASYNCIO</journal-type>
    <bindings-directory>/var/lib/artemis-instance/data/bindings</bindings-directory>
    <journal-directory>/var/lib/artemis-instance/data/journal</journal-directory>
    <large-messages-directory>/var/lib/artemis-instance/data/large-messages</large-messages-directory>
    <paging-directory>/var/lib/artemis-instance/data/paging</paging-directory>

    <connectors>
      <connector name="netty-connector">tcp://artemis-node3:61616</connector>
      <connector name="broker1-connector">tcp://artemis-master:61616</connector>
      <connector name="broker2-connector">tcp://artemis-slave:61616</connector>
      <connector name="broker4-connector">tcp://artemis-node4:61616</connector>
    </connectors>

    <cluster-connections>
      <cluster-connection name="hsm-cluster">
        <connector-ref>netty-connector</connector-ref>
        <message-load-balancing>OFF</message-load-balancing>
        <max-hops>1</max-hops>
        <static-connectors>
          <connector-ref>broker1-connector</connector-ref>
          <connector-ref>broker2-connector</connector-ref>
          <connector-ref>broker4-connector</connector-ref>
        </static-connectors>
      </cluster-connection>
    </cluster-connections>

    <acceptors>
      <acceptor name="openwire">tcp://0.0.0.0:61616?protocols=CORE,OPENWIRE;tcpSendBufferSize=1048576;tcpReceiveBufferSize=1048576</acceptor>
      <acceptor name="artemis">tcp://0.0.0.0:61617?protocols=CORE</acceptor>
      <acceptor name="amqp">tcp://0.0.0.0:61618?protocols=AMQP;anycastPrefix=queue://;multicastPrefix=topic://;tcpSendBufferSize=1048576;tcpReceiveBufferSize=1048576</acceptor>
    </acceptors>

    <security-enabled>false</security-enabled>

    <address-settings>
      <address-setting match="#">
        <dead-letter-address>DLQ</dead-letter-address>
        <expiry-address>ExpiryQueue</expiry-address>
        <redelivery-delay>5000</redelivery-delay>
        <max-delivery-attempts>3</max-delivery-attempts>
        <max-size-bytes>104857600</max-size-bytes>
        <message-counter-history-day-limit>10</message-counter-history-day-limit>
        <address-full-policy>PAGE</address-full-policy>
        <default-address-routing-type>ANYCAST</default-address-routing-type>
      </address-setting>
    </address-settings>

    <addresses>
      <address name="DLQ"><anycast><queue name="DLQ"/></anycast></address>
      <address name="ExpiryQueue"><anycast><queue name="ExpiryQueue"/></anycast></address>
      <address name="hsm.transparent.lb.in"><anycast><queue name="hsm.transparent.lb.in"/></anycast></address>
      <address name="hsm.transparent.lb.reply"><anycast><queue name="hsm.transparent.lb.reply"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-1"><anycast><queue name="hsm-transparent-lb-inbound-go-1"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-2"><anycast><queue name="hsm-transparent-lb-inbound-go-2"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-3"><anycast><queue name="hsm-transparent-lb-inbound-go-3"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-4"><anycast><queue name="hsm-transparent-lb-inbound-go-4"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-5"><anycast><queue name="hsm-transparent-lb-inbound-go-5"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-6"><anycast><queue name="hsm-transparent-lb-inbound-go-6"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-7"><anycast><queue name="hsm-transparent-lb-inbound-go-7"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-8"><anycast><queue name="hsm-transparent-lb-inbound-go-8"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-9"><anycast><queue name="hsm-transparent-lb-inbound-go-9"/></anycast></address>
      <address name="hsm-transparent-lb-inbound-go-10"><anycast><queue name="hsm-transparent-lb-inbound-go-10"/></anycast></address>
    </addresses>
  </core>
</configuration>
